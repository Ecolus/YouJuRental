<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gray_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Top search bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/primary"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_city"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="成都 ▾"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true" />

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="8dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp">

                <EditText
                    android:id="@+id/et_search"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:hint="搜索小区或区域"
                    android:paddingHorizontal="16dp"
                    android:textSize="14sp"
                    android:imeOptions="actionSearch"
                    android:singleLine="true" />
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/tv_ai"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="筛选"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/bg_filter_chip"
                android:backgroundTint="@color/accent"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="160dp"
                    android:layout_margin="12dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">

                    <androidx.viewpager2.widget.ViewPager2
                        android:id="@+id/vp_banner"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />
                </androidx.cardview.widget.CardView>

                <LinearLayout
                    android:id="@+id/layout_filter"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="12dp"
                    android:paddingBottom="8dp">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_price"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="租金区间"
                        style="@style/FilterChipStyle"
                        android:layout_marginEnd="8dp" />
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_type"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="户型"
                        style="@style/FilterChipStyle"
                        android:layout_marginEnd="8dp" />
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_rent_type"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="整租/合租"
                        style="@style/FilterChipStyle"
                        android:layout_marginEnd="8dp" />
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_decoration"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="装修"
                        style="@style/FilterChipStyle" />
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_houses"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="12dp"
                    android:paddingBottom="80dp"
                    android:nestedScrollingEnabled="false" />
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </LinearLayout>

    <!-- AI Assistant FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_ai"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="20dp"
        android:src="@drawable/ic_house"
        android:contentDescription="AI助手"
        app:fabSize="normal"
        app:backgroundTint="@color/primary"
        app:tint="@color/white"
        android:elevation="6dp" />
</FrameLayout>
